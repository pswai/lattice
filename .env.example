PORT=3000

# Database — set DATABASE_URL for Postgres, or DB_PATH for SQLite (default)
# DATABASE_URL=postgresql://user:password@host:5432/lattice
DB_PATH=./data/lattice.db
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000

TASK_REAP_TIMEOUT_MINUTES=30
TASK_REAP_INTERVAL_MS=60000
EVENT_RETENTION_DAYS=30
AGENT_HEARTBEAT_TIMEOUT_MINUTES=10
ADMIN_KEY=your-secret-admin-key-here
LOG_LEVEL=info
NODE_ENV=development
